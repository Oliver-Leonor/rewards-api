# ── Database (Neon Postgres) ──
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Redis (Upstash) ──
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# ── Server ──
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Worker ──
ENABLE_WORKER=true
